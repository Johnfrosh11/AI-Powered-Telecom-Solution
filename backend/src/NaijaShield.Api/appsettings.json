    "Audience": "naijashield-api",
    "ExpiryMinutes": "60"
  },
  "AzureOpenAI": {
    "Endpoint": "https://YOUR_RESOURCE.openai.azure.com/",
    "ApiKey": "REPLACE_WITH_KEY",
    "DeploymentName": "gpt-4o"
  },
  "AfricasTalking": {
    "ApiKey": "REPLACE_WITH_KEY",
    "Username": "sandbox",
    "SenderId": "NaijaShield"
  },
  "WhatsApp": {
    "AccessToken": "REPLACE_WITH_TOKEN",
    "PhoneNumberId": "REPLACE_WITH_PHONE_ID"
  },
  "NCC": {
    "BaseUrl": "https://ncc-reporting-stub.azure-api.net",
    "ApiKey": "REPLACE_WITH_KEY"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "https://app.naijashield.ng"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
