{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=NaijaShieldDb;Trusted_Connection=True;MultipleActiveResultSets=true",
    "Redis": "localhost:6379",
    "AzureStorage": "UseDevelopmentStorage=true",
    "ServiceBus": "Endpoint=sb://naijashield.servicebus.windows.net/;SharedAccessKeyName=..."
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS_IN_USER_SECRETS",
